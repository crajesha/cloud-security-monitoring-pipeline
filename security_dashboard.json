          },
          "editorMode": "code",
          "expr": "sum(increase(node_failed_ssh_logins_total[1m]))",
          "legendFormat": "Failed SSH/Min",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(flask_http_requests_total{status=~\"4..|5..\"}[1m])) * 60",
          "legendFormat": "App Errors/Min",
          "range": true,
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
